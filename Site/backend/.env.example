PORT=4000
# Local Docker: bolt://localhost:7687
# Neo4j Aura (prod): neo4j+s://xxxx.databases.neo4j.io  (copier depuis la console Aura, sans guillemets)
# Aura: USERNAME et DATABASE sont souvent l’id d’instance (fichier téléchargé à la création), pas "neo4j".
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4jpassword
# NEO4J_DATABASE=   # ex. id Aura ; laisser vide pour Docker local
CSV_STUDENTS_PATH=../moc_data/Résultats/database_etudiants_300k.csv
CSV_AMBASSADORS_PATH=../moc_data/Résultats/ambassadeurs_data_heavy.csv
IMPORT_BATCH_SIZE=2000
